@page "{id:int}"
@model hopefullyAWebForum.Pages.Shared.ViewUser
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TOAD | @(Model.SelectedUser?.Username ?? "User Not Found")</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --bg: #111111;
            --text-titles: #ffffff;
            --text-content: #d1d1d1;
            --muted: #888888;
            --border: #222222;
            --accent: #4ade80;
        }

        .light-mode {
            --bg: #ffffff;
            --text-titles: #111111;
            --text-content: #333333;
            --muted: #666666;
            --border: #eeeeee;
            --accent: #16a34a;
        }

        body {
            font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
            background-color: var(--bg);
            color: var(--text-content);
            line-height: 1.7;
        }

        h1, h2, h3 {
            color: var(--text-titles);
        }

        .action-link {
            display: inline-block;
            border: 2px solid var(--text-titles);
            padding: 8px 16px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            text-decoration: none;
            font-size: 0.75rem;
            color: var(--text-titles);
        }

        .action-link:hover {
            background-color: var(--text-titles);
            color: var(--bg);
        }

        .feed-item {
            padding: 2.5rem 1.5rem;
            margin: 0 -1.5rem;
            transition: background 0.2s ease;
            border-bottom: 1px solid var(--border);
        }

        .feed-item:hover {
            background-color: rgba(255, 255, 255, 0.03);
        }

        .light-mode .feed-item:hover {
            background-color: rgba(0, 0, 0, 0.02);
        }

        .user-green {
            color: var(--accent);
            font-weight: 500;
        }

        .toad-icon {
            color: var(--accent);
            opacity: 0.8;
        }

        .theme-btn {
            padding: 4px 12px;
            cursor: pointer;
            text-transform: uppercase;
            font-weight: 700;
            font-size: 0.7rem;
            border: 1px solid var(--border);
        }

        .theme-btn.active {
            background-color: var(--text-titles);
            color: var(--bg);
        }

        .tab-btn {
            position: relative;
            transition: all 0.2s ease;
        }

        .tab-btn.active {
            color: var(--text-titles);
            opacity: 1;
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 2px;
            background-color: var(--accent);
        }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col p-6 transition-colors duration-300">

<div class="w-full max-w-3xl mx-auto flex-grow space-y-12">

    <nav class="pt-8">
        <a asp-page="/ViewPosts" class="text-xs font-bold uppercase tracking-widest opacity-50 hover:opacity-100 transition-opacity">
            ← Back to Feed
        </a>
    </nav>

    @if (Model.SelectedUser != null)
    {
        <header class="flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="flex-shrink-0">
                <svg class="toad-icon w-24 h-24" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M4 18v-2a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v2" />
                    <path d="M6 12v-2a3 3 0 0 1 6 0v2" />
                    <path d="M12 12v-2a3 3 0 0 1 6 0v2" />
                    <line x1="7.5" y1="10.5" x2="9.5" y2="10.5" stroke-width="1.8" />
                    <line x1="14.5" y1="10.5" x2="16.5" y2="10.5" stroke-width="1.8" />
                    <line x1="7" y1="15" x2="17" y2="15" />
                </svg>
            </div>

            <div class="space-y-4">
                <div class="space-y-1">
                    <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--accent)]">Member Profile</div>
                    <h1 class="text-5xl md:text-6xl font-black tracking-tight uppercase leading-none">
                        @Model.SelectedUser.Username
                    </h1>
                    <p class="text-sm font-medium text-[var(--muted)]">
                        Active since <span class="text-[var(--text-titles)]">@Model.SelectedUser.JoinDate.ToString("MMM yyyy")</span>
                    </p>
                </div>
            </div>
        </header>

        <div class="space-y-0">
            <div class="flex gap-8 border-b border-[var(--border)]">
                <button onclick="showTab('threads')" id="tab-btn-threads" class="tab-btn active pb-4 text-xs font-bold uppercase tracking-widest opacity-40 hover:opacity-100">
                    Threads (@(Model.Posts?.Count ?? 0))
                </button>
                <button onclick="showTab('comments')" id="tab-btn-comments" class="tab-btn pb-4 text-xs font-bold uppercase tracking-widest opacity-40 hover:opacity-100">
                    Comments (@(Model.Comments?.Count ?? 0))
                </button>
            </div>

            <div id="tab-container">
                <main id="content-threads" class="tab-content">
                    @if (Model.Posts != null && Model.Posts.Any())
                    {
                        @foreach (var post in Model.Posts)
                        {
                            <article class="feed-item space-y-4">
                                <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-widest opacity-60">
                                    <span>Posted on @post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>

                                <h2 class="text-2xl font-bold tracking-tight">
                                    @post.Topic
                                </h2>

                                <p class="text-[var(--text-content)] text-sm line-clamp-2 leading-relaxed break-words opacity-80">
                                    @post.Content
                                </p>

                                <div class="pt-2">
                                    <a asp-page="/FocusPost" asp-route-id="@post.PostId" class="text-xs font-bold uppercase underline decoration-[var(--border)] underline-offset-8 hover:text-[var(--accent)] hover:decoration-[var(--accent)] transition-all">
                                        View Thread →
                                    </a>
                                </div>
                            </article>
                        }
                    }
                    else
                    {
                        <div class="py-20 text-center border-b border-[var(--border)]">
                            <p class="text-xs uppercase tracking-widest opacity-30 font-bold">No threads started by this user.</p>
                        </div>
                    }
                </main>

               <section id="content-comments" class="tab-content hidden space-y-0">
    @if (Model.Comments != null && Model.Comments.Any())
    {
        @foreach (var comment in Model.Comments)
        {
            <article class="feed-item space-y-4">
                <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-widest opacity-80">
                    <span class="user-green">@comment.AuthorName</span>
                    <span class="opacity-40">On: @comment.CommentedAt.ToString("MMM dd, yyyy HH:mm")</span>
                </div>

                <h2 class="text-2xl font-bold tracking-tight">
                    @* Pokud tvůj model nemá Topic, použijeme tohle sjednocené označení *@
                    RE: THREAD #@comment.PostId
                </h2>

                <p class="text-[var(--text-content)] text-base line-clamp-3 leading-relaxed break-words">
                    @comment.Content
                </p>

                <div class="pt-2">
                    <a asp-page="/FocusPost" asp-route-id="@comment.PostId" class="text-xs font-bold uppercase underline decoration-[var(--border)] underline-offset-8 hover:text-[var(--accent)] hover:decoration-[var(--accent)] transition-all">
                        View Context →
                    </a>
                </div>
            </article>
        }
    }
    else
    {
        <div class="py-20 text-center border-b border-[var(--border)]">
            <p class="text-sm uppercase tracking-widest opacity-30 font-bold italic">No comments in history.</p>
        </div>
    }
</section>            </div>
        </div>
    }
    else
    {
        <header class="py-20 text-center">
            <h1 class="text-4xl font-black uppercase italic opacity-20">404 // User Not Found</h1>
            <a asp-page="/ViewPosts" class="mt-8 action-link">Return to Feed</a>
        </header>
    }
</div>

<footer class="w-full max-w-3xl mx-auto mt-24 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 text-[10px] font-bold uppercase tracking-widest opacity-30 border-t border-[var(--border)] pt-6 pb-8">
    <div>Built by Matespok // C# // 2026</div>
    <div class="flex">
        <div id="btnDark" class="theme-btn active">Dark</div>
        <div id="btnLight" class="theme-btn">Light</div>
    </div>
</footer>

<script>
    // Theme Engine
    const body = document.body;
    const btnDark = document.getElementById('btnDark');
    const btnLight = document.getElementById('btnLight');

    function setTheme(isLight) {
        if (isLight) {
            body.classList.add('light-mode');
            btnLight.classList.add('active');
            btnDark.classList.remove('active');
            localStorage.setItem('theme', 'light');
        } else {
            body.classList.remove('light-mode');
            btnDark.classList.add('active');
            btnLight.classList.remove('active');
            localStorage.setItem('theme', 'dark');
        }
    }

    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'light') setTheme(true);

    btnLight.addEventListener('click', () => setTheme(true));
    btnDark.addEventListener('click', () => setTheme(false));

    // Tab Switcher
    function showTab(tabName) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        document.getElementById('content-' + tabName).classList.remove('hidden');

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });

        document.getElementById('tab-btn-' + tabName).classList.add('active');
    }
</script>
</body>
</html>
